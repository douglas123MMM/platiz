{
  "installCommand": "cd platiz && npm install && cd frontend && npm install",
  "buildCommand": "cd platiz/frontend && npm run build",
  "outputDirectory": "platiz/frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 256,
      "maxDuration": 10
    }
  }
}
